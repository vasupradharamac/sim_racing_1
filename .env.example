# DATA_DIR: Directory where racing_data.csv is stored.
# On Railway, set this to your mounted volume path (e.g. /data)
# so race history survives restarts and redeploys.
# Defaults to the project root if unset (fine for local dev).
DATA_DIR=/data

# PORT: Provided automatically by Railway at runtime. No need to set manually.
# Defaults to 3000 for local dev.
PORT=3000
